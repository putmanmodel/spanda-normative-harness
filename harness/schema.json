{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Spanda Normative POW Log Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "demo_id",
    "normative_ids",
    "mode",
    "fixture_path",
    "fixture_hash",
    "pass",
    "decision",
    "rationale",
    "evidence",
    "timestamp_utc"
  ],
  "properties": {
    "demo_id": { "type": "string" },
    "normative_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "mode": { "type": "string", "enum": ["proof", "break"] },
    "fixture_path": { "type": "string" },
    "fixture_hash": { "type": "string" },
    "pass": { "type": "boolean" },
    "decision": { "type": "string" },
    "rationale": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "timestamp_utc": { "type": "string" }
  }
}
